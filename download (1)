export const Dashboard: React.FC<DashboardProps> = ({ scenario }) => {
  const [activeTab, setActiveTab] = useState<"geral" | "adocao" | "suporte" | "relacionamento">("geral");
  const [hoveredPoint, setHoveredPoint] = useState<{ index: number; x: number; y: number } | null>(null);

  const data = scenario.dashboardData;
  const hs = data.healthScore;
  const mock = getMockDataByScenario(scenario.id);

  // Setup color theme according to actual Health Score
  let themeColor = "#ff4444";
  let themeBg = "bg-[#ff4444]/15 border-[#ff4444]/30 text-[#ff4444]";
  let themeTextClass = "text-[#ff4444]";
  if (hs > 80) {
    themeColor = "#00ff88";
    themeBg = "bg-[#00ff88]/15 border-[#00ff88]/30 text-[#00ff88]";
    themeTextClass = "text-[#00ff88]";
  } else if (hs >= 50) {
    themeColor = "#D46900";
    themeBg = "bg-[#D46900]/15 border-[#D46900]/30 text-[#D46900]";
    themeTextClass = "text-[#D46900]";
  }

  // Radial track calculations
  const radius = 48;
  const circumference = 2 * Math.PI * radius;
  const strokeDashoffset = circumference - (hs / 100) * circumference;

  return (
    <div id="v360-dashboard-root" className="bg-[#050B2E]/60 backdrop-blur-md border border-white/10 rounded-[15px] p-6 text-white space-y-6 shadow-2xl relative overflow-hidden flex flex-col justify-between">
      
      {/* Absolute decorative backlights */}
      <div className="absolute -top-20 -right-20 w-48 h-48 rounded-full bg-[#6A38B3] blur-[80px] opacity-20 pointer-events-none"></div>
      <div className="absolute -bottom-20 -left-20 w-48 h-48 rounded-full bg-[#D46900] blur-[80px] opacity-15 pointer-events-none"></div>

      {/* DASHBOARD CONSOLE STRIP */}
      <div className="relative flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/10 pb-4">
        <div className="flex items-center space-x-3">
          <div className="bg-[#6A38B3]/20 border border-[#6A38B3]/50 p-2.5 rounded-[12px] text-[#D46900]">
            <LayoutDashboard size={20} />
          </div>
          <div>
            <div className="flex items-center space-x-2">
              <span className="text-[9px] font-mono tracking-[0.2em] text-[#D46900] font-bold uppercase">Painel de Métricas Real-Time</span>
              <span className="w-1.5 h-1.5 bg-[#00ff88] rounded-full animate-ping"></span>
            </div>
            <h2 id="dashboard-client-title" className="text-xl font-display uppercase tracking-tight text-white leading-none font-normal mt-0.5">
              Simulação: {scenario.profile.client}
            </h2>
          </div>
        </div>

        {/* Current Health Score Level Widget */}
        <div className="flex items-center space-x-3 self-start sm:self-center">
          <div className="text-right hidden md:block font-mono">
            <span className="text-[9px] text-[#E0E0E0] uppercase block">Foco de Atuação</span>
            <span className="text-[10px] font-bold text-[#D46900] uppercase block leading-none mt-0.5">{data.quadrant.split(" (")[0]}</span>
          </div>
          <div className={`${themeBg} border px-4 py-1.5 rounded-[12px] flex items-center space-x-2 text-[10px] uppercase font-bold tracking-wider`}>
            <Activity size={12} />
            <span>{hs <= 50 ? "Risco Crítico" : hs <= 80 ? "Neutro / Monitoramento" : "Saudável / Expansão"}</span>
          </div>
        </div>
      </div>

      {/* HISTORICAL GRAPHICS AND MATRIX TOP ROW */}
      <div className="grid grid-cols-1 xl:grid-cols-12 gap-6">
        
        {/* WIDGET A: CONCENTRIC DIAL MEASURE (3 cols) */}
        <div className="xl:col-span-3 bg-white/5 border border-white/5 rounded-[15px] p-4 flex flex-col items-center justify-center text-center relative">
          <span className="text-[9px] font-mono text-[#E0E0E0] uppercase tracking-wider font-bold mb-3 block">Health Score Geral</span>
          
          <div className="relative flex items-center justify-center">
            <svg className="w-32 h-32 transform -rotate-90">
              <circle
                cx="64"
                cy="64"
                r={radius}
                className="stroke-white/5"
                strokeWidth="8"
                fill="transparent"
              />
              <circle
                cx="64"
                cy="64"
                r={radius}
                stroke={themeColor}
                strokeWidth="8"
                fill="transparent"
                strokeDasharray={circumference}
                strokeDashoffset={strokeDashoffset}
                strokeLinecap="round"
                className="transition-all duration-1000 ease-out"
              />
            </svg>
            <div className="absolute text-center flex flex-col items-center justify-center">
              <span id="dashboard-gauge-value" className={`text-4xl font-display font-normal tracking-tight block leading-none ${themeTextClass}`}>
                {hs}
              </span>
              <span className="text-[8px] font-mono text-gray-400 uppercase tracking-widest font-bold mt-1">Pontos</span>
            </div>
          </div>

          <div className="w-full text-[9px] font-mono bg-[#050B2E] border border-white/5 px-2.5 py-1.5 rounded-[8px] text-gray-300 mt-4 leading-normal">
            <div>Foco: <span className="font-extrabold text-[#D46900] uppercase">{scenario.profile.segment}</span></div>
          </div>
        </div>

        {/* WIDGET B: TIME-SERIES EVOLUTION GRAPH (5 cols) */}
        <div className="xl:col-span-5 bg-white/5 border border-white/5 rounded-[15px] p-4 flex flex-col justify-between relative">
          <div className="flex items-center justify-between mb-2">
            <span className="text-[10px] font-mono text-[#D46900] uppercase tracking-wider font-bold">Evolução do Health Score</span>
            <span className="text-[9px] font-mono text-gray-400">Últimos 6 Meses</span>
          </div>

          {/* SVG Historical Chart */}
          <div className="relative w-full h-32 mt-2">
            <svg className="w-full h-full overflow-visible">
              {/* Grid Lines */}
              <line x1="0" y1="20" x2="100%" y2="20" stroke="rgba(255,255,255,0.05)" strokeDasharray="3 3" />
              <line x1="0" y1="60" x2="100%" y2="60" stroke="rgba(255,255,255,0.05)" strokeDasharray="3 3" />
              <line x1="0" y1="100" x2="100%" y2="100" stroke="rgba(255,255,255,0.05)" strokeDasharray="3 3" />

              {/* Dynamic Path Maker */}
              {(() => {
                const points = mock.healthHistory;
                const width = 280; // approximate viewbox width
                const height = 110;
                // Min potential score is 0, Max potential is 100
                const mapY = (val: number) => height - (val / 100) * height + 10;
                const mapX = (idx: number) => (idx / (points.length - 1)) * 90 + "%";

                const pathD = points.map((p, idx) => {
                  const xCoord = (idx / (points.length - 1)) * 100; // % values
                  return `${idx === 0 ? "M" : "L"} ${xCoord}% ${mapY(p)}`;
                }).join(" ");

                return (
                  <>
                    <path
                      d={pathD}
                      fill="none"
                      stroke="url(#gradient-line)"
                      strokeWidth="3.5"
                      strokeLinecap="round"
                    />

                    {/* Gradient Definitions */}
                    <defs>
                      <linearGradient id="gradient-line" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stopColor="#D46900" />
                        <stop offset="100%" stopColor="#6A38B3" />
                      </linearGradient>
                    </defs>

                    {/* Nodes */}
                    {points.map((p, idx) => {
                      const yVal = mapY(p);
                      const xPerc = (idx / (points.length - 1)) * 100 + "%";
                      const isCurrentNode = idx === points.length - 1;

                      return (
                        <g
                          key={idx}
                          className="cursor-pointer group"
                          onMouseEnter={() => setHoveredPoint({ index: idx, x: idx * 56, y: yVal })}
                          onMouseLeave={() => setHoveredPoint(null)}
                        >
                          <circle
                            cx={xPerc}
                            cy={yVal}
                            r={isCurrentNode ? "6" : "4.5"}
                            className={`${
                              isCurrentNode ? "fill-[#00ff88]" : "fill-[#D46900]"
                            } stroke-[#050B2E] stroke-2 hover:r-7 transition-all duration-200`}
                          />
                        </g>
                      );
                    })}
                  </>
                );
              })()}
            </svg>

            {/* Custom Tooltip */}
            {hoveredPoint !== null && (
              <div
                className="absolute bg-[#050B2E]/95 border border-white/20 p-2 rounded-lg text-[9px] font-mono shadow-xl z-20 pointer-events-none"
                style={{
                  left: `${(hoveredPoint.index / 5) * 80}%`,
                  bottom: "105%"
                }}
              >
                <div className="font-bold text-[#D46900] uppercase">{mock.historicalLabels[hoveredPoint.index]}</div>
                <div className="text-white mt-0.5">Health Score: <span className="font-extrabold text-[#00ff88]">{mock.healthHistory[hoveredPoint.index]}</span></div>
              </div>
            )}
          </div>

          {/* Month Labels */}
          <div className="flex justify-between text-[8px] text-gray-400 font-mono pt-1">
            {mock.historicalLabels.map((l, i) => (
              <span key={i}>{l}</span>
            ))}
          </div>
        </div>

        {/* WIDGET C: POTENTIAL X HEALTH SCORE GRID MATRIX (4 cols) */}
        <div className="xl:col-span-4 bg-white/5 border border-[#ffffff]/5 rounded-[15px] p-4 flex flex-col justify-between">
          <div className="flex items-center justify-between mb-2">
            <span className="text-[10px] font-mono text-[#D46900] uppercase tracking-wider font-bold">Matriz: Potencial X Health Score</span>
            <span className="text-[8px] font-mono text-gray-400 uppercase">Foco de Atuação</span>
          </div>

          {/* 2x2 Grid Simulation */}
          <div className="grid grid-cols-2 gap-2 text-[8.5px] font-bold uppercase tracking-wider my-1 relative">
            
            {/* Top Left: Estabilização para Retenção */}
            <div className={`p-2.5 rounded-[10px] border flex flex-col justify-between min-h-[58px] ${
              scenario.dashboardData.quadrant.includes("Estabilização")
                ? "bg-[#6A38B3]/25 border-[#6A38B3] text-white"
                : "bg-white/3 border-white/5 text-gray-500"
            }`}>
              <span className="font-mono text-[7px] text-[#A0A0A0] leading-none block uppercase">POTENCIAL ALTO</span>
              <span className="font-sans leading-snug">Estabilização / Retenção</span>
            </div>

            {/* Top Right: Foco em Expansão */}
            <div className={`p-2.5 rounded-[10px] border flex flex-col justify-between min-h-[58px] ${
              scenario.dashboardData.quadrant.includes("Expansão")
                ? "bg-[#D46900]/25 border-[#D46900] text-white"
                : "bg-white/3 border-white/5 text-gray-500"
            }`}>
              <span className="font-mono text-[7px] text-[#A0A0A0] leading-none block uppercase text-right">POTENCIAL ALTO</span>
              <span className="font-sans leading-snug">Foco em Expansão / Upsell</span>
            </div>

            {/* Bottom Left: Risco Técnico */}
            <div className={`p-2.5 rounded-[10px] border flex flex-col justify-between min-h-[58px] ${
              scenario.dashboardData.quadrant.includes("Risco") || (hs < 50 && !scenario.dashboardData.quadrant.includes("Expansão") && !scenario.dashboardData.quadrant.includes("Estabilização"))
                ? "bg-[#ff4444]/25 border-[#ff4444] text-white"
                : "bg-white/3 border-white/5 text-gray-500"
            }`}>
              <span className="font-mono text-[7px] text-[#A0A0A0] leading-none block uppercase">POTENCIAL BAIXO</span>
              <span className="font-sans leading-snug">Risco Técnico / Recuperação</span>
            </div>

            {/* Bottom Right: Atendimento Clássico */}
            <div className={`p-2.5 rounded-[10px] border flex flex-col justify-between min-h-[58px] ${
              scenario.dashboardData.quadrant.includes("Defesa") || scenario.dashboardData.quadrant.includes("Membro") || scenario.dashboardData.quadrant.includes("Atendimento")
                ? "bg-[#00ff88]/20 border-[#00ff88]/50 text-white"
                : "bg-white/3 border-white/5 text-gray-500"
            }`}>
              <span className="font-mono text-[7px] text-[#A0A0A0] leading-none block uppercase text-right">POTENCIAL BAIXO</span>
              <span className="font-sans leading-snug">Atendimento Clássico / Defesa</span>
            </div>

            {/* Dynamic Plotted Client Dot */}
            {(() => {
              const insideExpanding = scenario.dashboardData.quadrant.includes("Expansão");
              const insideRetain = scenario.dashboardData.quadrant.includes("Estabilização");
              const insideDefense = scenario.dashboardData.quadrant.includes("Defesa") || scenario.dashboardData.quadrant.includes("Membro") || scenario.dashboardData.quadrant.includes("Atendimento");

              let dotStyle = { top: "25%", left: "75%" }; // Expansão (top-right)
              if (insideRetain) {
                dotStyle = { top: "25%", left: "25%" }; // Estabilização (top-left)
              } else if (insideDefense) {
