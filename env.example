import React from "react";
import { Scenario } from "../types";
import { User, ShieldAlert, Award, FileText, CheckCircle2, AlertTriangle, AlertCircle } from "lucide-react";

interface DossierProps {
  scenario: Scenario;
}

export const Dossier: React.FC<DossierProps> = ({ scenario }) => {
  return (
    <div id="dossier-root" className="bg-[#E0E0E0] rounded-[15px] p-6 text-[#050B2E] space-y-6 shadow-2xl relative overflow-hidden flex flex-col border border-white/20">
      {/* Target Logo & Client Name */}
      <div className="flex items-center justify-between border-b border-black/10 pb-4">
        <div>
          <span className="text-[10px] tracking-[0.2em] text-[#D46900] font-black uppercase block mb-1">Dossiê do Cliente</span>
          <h2 id="dossier-client-name" className="text-3xl font-display font-normal uppercase tracking-tight text-[#050B2E] m-0 leading-none">
            {scenario.profile.client}
          </h2>
        </div>
        <div className="bg-[#050B2E] text-white text-[10px] px-3       py-1 rounded-full uppercase font-bold tracking-widest">
          {scenario.profile.segment}
        </div>
      </div>

      {/* Corporate profile */}
      <div id="dossier-profile-card" className="bg-white rounded-[12px] p-4 text-xs md:text-sm leading-relaxed space-y-3 shadow-sm border border-black/5 text-[#050B2E]">
        <div className="flex items-center space-x-2 text-[#D46900]">
          <FileText size={18} />
          <h3 className="font-extrabold uppercase tracking-wider text-xs">Perfil Corporativo e Contexto</h3>
        </div>
        <p className="text-[#333333] font-light leading-relaxed">{scenario.profile.context}</p>
        <div className="grid grid-cols-2 gap-4 pt-2 text-xs border-t border-black/10">
          <div>
            <span className="text-gray-500 block font-bold text-[9px] uppercase tracking-wider">Tempo de Casa:</span>
            <span className="text-[#050B2E] font-extrabold">{scenario.profile.duration}</span>
          </div>
          <div>
            <span className="text-gray-500 block font-bold text-[9px] uppercase tracking-wider">Janela Contratual:</span>
            <span className="text-[#050B2E] font-extrabold">{scenario.profile.window}</span>
          </div>
        </div>
      </div>

      {/* Stakeholders mapping */}
      <div id="dossier-stakeholders-card" className="space-y-4">
        <div className="flex items-center space-x-2 text-[#D46900]">
          <User size={18} />
          <h3 className="font-extrabold uppercase tracking-wider text-xs">Mapeamento de Stakeholders</h3>
        </div>
        <div className="grid grid-cols-1 gap-4">
          {scenario.stakeholders.map((s, idx) => (
            <div key={idx} className="bg-white rounded-[12px] p-4 flex flex-col justify-between space-y-3 border border-black/5 shadow-sm text-[#050B2E]">
              <div>
                <div className="flex items-start justify-between">
                  <div>
                    <h4 className="font-black text-[#050B2E] text-base leading-tight">{s.name}</h4>
                    <span className="text-xs text-[#6A38B3] font-bold italic">{s.role}</span>
                  </div>
                  <span className="text-[9px] bg-[#6A38B3]/10 text-[#6A38B3] border border-[#6A38B3]/20 px-2.5 py-0.5 rounded-full uppercase font-black tracking-wide">
                    {s.influence.split(" ")[0]} {s.influence.split(" ")[1]}
                  </span>
                </div>
                <div className="text-xs text-gray-600 mt-2 font-medium">
                  {s.influence}
                </div>
                <p className="text-xs text-[#444444] mt-1 pr-2 leading-relaxed font-light">
                  {s.profile}
                </p>
              </div>
              <div className="bg-[#050B2E] text-white border-l-4 border-l-[#D46900] p-3.5 rounded-[10px] text-xs italic relative mt-2 shrink-0">
                <span className="absolute -top-2 left-3 bg-[#050B2E] px-1.5 text-[8px] text-[#A0A0A0] uppercase font-mono tracking-widest font-bold">
                  Comentário Recente
                </span>
                "{s.comment}"
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Incident History & Tech Status */}
      <div id="dossier-incidents-card" className="bg-[#ff4444]/10 border-2 border-[#ff4444]/40 rounded-[12px] p-4 space-y-3">
        <div className="flex items-center space-x-2 text-[#ff4444]">
          <ShieldAlert size={18} />
          <h3 className="font-black uppercase tracking-wider text-xs">Histórico de Incidentes (Fora do Painel)</h3>
        </div>
        <div className="flex items-start space-x-3 text-sm">
          <AlertCircle className="text-[#ff4444] shrink-0 mt-0.5" size={18} />
          <div>
            <span className="text-xs font-mono font-black text-[#ff4444] uppercase block">
              {scenario.incidents.status}
            </span>
            <p className="text-[#333333] mt-1 text-xs leading-relaxed font-medium">{scenario.incidents.text}</p>
          </div>
        </div>
      </div>

      {/* Eligibility Matrix */}
      <div id="dossier-eligibility-card" className="bg-white rounded-[12px] p-4 space-y-4 border border-black/5 shadow-sm text-[#050B2E]">
        <div className="flex items-center space-x-2 text-[#D46900] border-b border-black/5 pb-2">
          <Award size={18} />
          <h3 className="font-extrabold uppercase tracking-wider text-xs">Matriz de Elegibilidade Técnica (Hub de CS)</h3>
        </div>
        <div className="grid grid-cols-1 md:grid-cols-3 gap-4 text-xs font-mono">
          {/* Já Possui */}
          <div className="space-y-2">
            <span className="text-[#00aa5c] font-black block uppercase flex items-center space-x-1 text-[10px] tracking-wide">
              <CheckCircle2 size={12} className="inline mr-1" /> Já Possui ({scenario.eligibility.has.length})
            </span>
            <div className="bg-[#00aa5c]/5 border border-[#00aa5c]/20 max-h-[160px] overflow-y-auto rounded-[10px] p-2 space-y-1 block">
              {scenario.eligibility.has.length === 0 ? (
                <span className="text-gray-400 italic block text-[10px]">Nenhum</span>
              ) : (
                scenario.eligibility.has.map((item, idx) => (
                  <span key={idx} className="block text-[#050B2E] py-0.5 border-b border-black/5 last:border-b-0 break-words text-[10px] leading-relaxed">
                    • {item}
                  </span>
                ))
              )}
            </div>
          </div>

          {/* Elegível */}
          <div className="space-y-2">
            <span className="text-[#aa7f00] font-black block uppercase flex items-center space-x-1 text-[10px] tracking-wide">
              <AlertTriangle size={12} className="inline mr-1" /> Elegível ({scenario.eligibility.eligible.length})
            </span>
            <div className="bg-[#aa7f00]/5 border border-[#aa7f00]/20 max-h-[160px] overflow-y-auto rounded-[10px] p-2 space-y-1 block">
              {scenario.eligibility.eligible.length === 0 ? (
                <span className="text-gray-400 italic block text-[10px]">Nenhum</span>
              ) : (
                scenario.eligibility.eligible.map((item, idx) => (
                  <span key={idx} className="block text-[#050B2E] py-0.5 border-b border-black/5 last:border-b-0 break-words text-[10px] leading-relaxed">
                    • {item}
                  </span>
                ))
              )}
            </div>
          </div>

          {/* Não Elegível */}
          <div className="space-y-2">
            <span className="text-[#cc2c2c] font-black block uppercase flex items-center space-x-1 text-[10px] tracking-wide">
              <AlertCircle size={12} className="inline mr-1" /> Não Elegível ({scenario.eligibility.notEligible.length})
            </span>
            <div className="bg-[#cc2c2c]/5 border border-[#cc2c2c]/20 max-h-[160px] overflow-y-auto rounded-[10px] p-2 space-y-1 block">
              {scenario.eligibility.notEligible.length === 0 ? (
                <span className="text-gray-400 italic block text-[10px]">Nenhum</span>
              ) : (
                scenario.eligibility.notEligible.map((item, idx) => (
                  <span key={idx} className="block text-gray-500 py-0.5 border-b border-black/5 last:border-b-0 break-words line-through decoration-[#cc2c2c]/40 text-[10px] leading-relaxed">
                    • {item}
                  </span>
                ))
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};
